#
# Multimap -- https://rspamd.com/doc/modules/multimap.html
#

#
{% if env.bypass_score -%}
# bypass group of rules -- add score {= env.bypass_score =}
{% else -%}
# bypass prefilter rules
{% endif -%}
#
BYPASS_SENDER {
    {% if env.bypass_score -%}
    group = "bypass";
    score = {= env.bypass_score =};
    {% else -%}
    prefilter = true;
    action = "accept";
    {% endif -%}
    type = "from";
    filter = "email";
    map = ["${DBDIR}/bypass_sender.map"];
}

BYPASS_SENDER_DOMAIN {
    {% if env.bypass_score -%}
    group = "bypass";
    score = {= env.bypass_score =};
    {% else -%}
    prefilter = true;
    action = "accept";
    {% endif -%}
    type = "from";
    filter = "email:domain";
    map = ["${DBDIR}/bypass_sender_domain.map"];
}

BYPASS_RECIPIENT {
    {% if env.bypass_score -%}
    group = "bypass";
    score = {= env.bypass_score =};
    {% else -%}
    prefilter = true;
    action = "accept";
    {% endif -%}
    type = "rcpt";
    filter = "email";
    map = ["${DBDIR}/bypass_recipient.map"];
}

BYPASS_RECIPIENT_DOMAIN {
    {% if env.bypass_score -%}
    group = "bypass";
    score = {= env.bypass_score =};
    {% else -%}
    prefilter = true;
    action = "accept";
    {% endif -%}
    type = "rcpt";
    filter = "email:domain";
    map = ["${DBDIR}/bypass_recipient_domain.map"];
}

BYPASS_IP {
    {% if env.bypass_score -%}
    group = "bypass";
    score = {= env.bypass_score =};
    {% else -%}
    prefilter = true;
    action = "accept";
    {% endif -%}
    type = "ip";
    map = ["${DBDIR}/bypass_ip.map"];
}

#
{% if env.block_score -%}
# block group of rules -- add score {= env.block_score =}
{% else -%}
# block prefilter rules
{% endif -%}
#
BLOCK_SENDER_TLD {
    {% if env.block_score -%}
    group = "block";
    score = {= env.block_score =};
    {% else -%}
    prefilter = true;
    action = "reject";
    {% endif -%}
    regexp = true;
    type = "from";
    filter = 'email:domain:tld';
    map = ["${DBDIR}/block_sender_tld.map"];
}

BLOCK_SENDER_DOMAIN {
    {% if env.block_score -%}
    group = "block";
    score = {= env.block_score =};
    {% else -%}
    prefilter = true;
    action = "reject";
    {% endif -%}
    regexp = true;
    type = "from";
    filter = 'email:domain';
    map = ["${DBDIR}/block_sender_domain.map"];
}

BLOCK_SENDER {
    {% if env.block_score -%}
    group = "block";
    score = {= env.block_score =};
    {% else -%}
    prefilter = true;
    action = "reject";
    {% endif -%}
    header = "from";
    type = "header";
    filter = 'email';
    map = ["${DBDIR}/block_sender.map"];
}
