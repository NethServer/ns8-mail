import json
import sys
import agent
import mail
from sqlite3 import IntegrityError

request = json.load(sys.stdin)
sdb = mail.pcdb_connect()
mbxn = request['mailbox']
rights_map = mail.get_rights_map()

try:

    cur = sdb.cursor()

    # Remove all destmap entries pointing to this public mailbox, across all
    # domains and addresses (e.g. toto@example.com → public mailbox toto).
    cur.execute("""DELETE FROM destmap WHERE dest=?""", ("vmail+" + mbxn,))
    # Remove address entries that have no remaining destinations.
    cur.execute("""DELETE FROM addresses WHERE NOT EXISTS"""
        """ (SELECT 1 FROM destmap AS d WHERE d.alocal = addresses.alocal AND d.domain = addresses.domain)""")

    # Destroy the mailbox and its contents
    mail.doveadm_query("mailboxDelete", {"mailbox": [mbxn], "user": "vmail", "recursive": True})

except mail.DoveadmError as dex:
    if dex.code == 68:
        # Mailbox was already gone from Dovecot (e.g., deleted via webmail client).
        # DB cleanup is still valid – commit it.
        sdb.commit()
    else:
        sdb.rollback()
        raise

else:
    sdb.commit()

finally:
    sdb.close()
